# PostgreSQL connection string. Local: postgresql://USER:PASS@HOST:PORT/DB_NAME
# Production: get this from Supabase → Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/heart_disease_db

# JWT signing key. Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# JWT algorithm (default HS256)
ALGORITHM=HS256

# JWT access-token lifetime in minutes (default 60)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Initial admin user — used by create_admin.py
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@cardioai.com
ADMIN_PASSWORD=

# Comma-separated list of allowed CORS origins for the frontend
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
